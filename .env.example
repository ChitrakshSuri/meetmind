# OpenAI
OPENAI_API_KEY=your_openai_key_here

# MeetingBaaS v2 API — https://auth.meetingbaas.com (~$0.10/meeting)
MEETINGBAAS_API_KEY=mb-your_key_here

# Jira / Atlassian
ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net
ATLASSIAN_API_TOKEN=your_token
ATLASSIAN_EMAIL=your@email.com
JIRA_PROJECT_KEY=YOUR_PROJECT

# Webhook — set a random secret and configure the same in MeetingBaaS dashboard
WEBHOOK_SECRET=

# LangSmith (optional — set to false to disable tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_key_here
LANGCHAIN_PROJECT=meetmind

# Database
DATABASE_URL=postgresql+asyncpg://meetmind:meetmind@localhost:5432/meetmind
POSTGRES_PASSWORD=meetmind

# App
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
WEBHOOK_BASE_URL=https://your-public-url.com
